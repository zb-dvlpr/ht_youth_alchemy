{
  "name": "ht_youth_alchemy",
  "version": "7.2.8",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run lint && npm run check:i18n && npm run check:chpp-permissions && npm run check:readme-version && npm run check:audit && next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "check:version": "node scripts/check-version.js",
    "check:i18n": "node scripts/check-i18n.js",
    "check:chpp-permissions": "node scripts/check-chpp-permissions.js",
    "check:readme-version": "node scripts/check-readme-version.js",
    "check:audit": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "fast-xml-parser": "^5.9.3",
    "next": "^16.2.9",
    "oauth-1.0a": "^2.2.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "typescript": "^6"
  }
}
